\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Second-order compensation strategies for unstructured and semi-structured pruning. SparseGPT removes one scalar weight per step and compensates using one column of $\hat  {H}^{-1}$, while MRP removes an N:M group jointly and uses the block $(\hat  {H}^{-1}_{MM})^{-1}$ to model interactions among simultaneously removed weights.}}{47}{figure.caption.53}\protected@file@percent }
\newlabel{fig:hessian_compensation}{{3.2}{47}{Second-order compensation strategies for unstructured and semi-structured pruning. SparseGPT removes one scalar weight per step and compensates using one column of $\hat {H}^{-1}$, while MRP removes an N:M group jointly and uses the block $(\hat {H}^{-1}_{MM})^{-1}$ to model interactions among simultaneously removed weights}{figure.caption.53}{}}
