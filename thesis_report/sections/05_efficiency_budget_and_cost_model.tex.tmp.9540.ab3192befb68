\captionof{table}{Per layer compute contribution for an illustrative candidate at $\seqlen = 128$. Costs are in millions of operations.}
\label{tab:cost_example}
\begin{tabular}{cccccc}
\toprule
$\ell$ & $\actl$ & $\nactl$ & Head & Neuron & Total \\
\midrule
0  & 2 & 112 & 25 & 22 & 47 \\
1  & 3 & 96  & 38 & 19 & 57 \\
2  & 2 & 64  & 25 & 13 & 38 \\
3  & 2 & 64  & 25 & 13 & 38 \\
4  & 0 & 16  & 0  & 3  & 3  \\
5  & 0 & 16  & 0  & 3  & 3  \\
6  & 0 & 0   & 0  & 0  & 0  \\
7  & 1 & 32  & 13 & 6  & 19 \\
